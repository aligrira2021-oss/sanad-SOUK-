rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidProduct(data) {
       return data.title is string && data.title.size() <= 200 &&
              data.description is string && data.description.size() <= 5000 &&
              data.category is string && data.category.size() <= 100 &&
              data.location is string && data.location.size() <= 100 &&
              data.sellerId is string && data.sellerId.size() <= 128 &&
              data.views is number && data.likes is number;
    }

    match /products/{productId} {
       allow read: if true;
       allow create: if isValidProduct(request.resource.data);
       allow update: if isValidProduct(request.resource.data);
       allow delete: if true;
    }
    
    match /systemUsers/{userId} {
       allow read, write: if true;
    }
    match /systemRequests/{reqId} {
       allow read, write: if true;
    }
    match /broadcasts/{bid} {
       allow read, write: if true;
    }
  }
}
